pipeline {
    agent any
    environment {
        PYTHON = 'C:\\Users\\Le\\AppData\\Local\\Programs\\Python\\Python314\\python.exe'
    }

    stages {
        stage('Checkout') {
            steps{
                checkout scm
            }
        }

        stage('Setup Python') {
            steps {
                bat '${env.PYTHON} --version'
            }
        }

        stage('Extract'){
            steps {
                bat '${env.PYTHON} extract.py'
            }
        }
    }
}
