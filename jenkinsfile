pipeline {
    agent any

    environment {
        PYTHON = 'C:\\Users\\Le\\AppData\\Local\\Programs\\Python\\Python314\\python.exe'
    }

    stages {
        stage ('checkout') {
            steps {
                checkout scm
            }
        }
        stage ('python version') {
            steps {
                bat '%PYTHON% --version'
            }
        }
        stage ('extract') {
            steps {
                bat '%PYTHON% extract.py'
            }
        }
    }
}