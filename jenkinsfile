pipeline {
    agent any

    environment {
        PYTHON = 'C:\\Users\\Le\\AppData\\Local\\Programs\\Python\\Python314\\python.exe'
    }

    stages {
        stage {
            steps ('checkout') {
                checkout scm
            }
        }
        stage {
            steps ('python version') {
                bat 'python --version'
            }
        }
        stage (
            steps ('extract') {
                bat 'python extract.py'
            }
        )
    }
}